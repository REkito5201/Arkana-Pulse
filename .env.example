BOT_TOKEN=your-telegram-bot-token-here
ADMIN_ID=123456789

# Optional Binance API keys (can be left empty for public data)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Redis connection string
REDIS_URL=redis://redis:6379/0

# Whales: free explorer APIs (get keys at etherscan.io, bscscan.com, polygonscan.com).
# If any of these keys is set, whale-worker will prefer direct explorer polling.
# If none is set, whale-worker will use WHALE_API_URL provider instead.
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
POLYGONSCAN_API_KEY=
# Optional: internal whale provider API (preferred for multi-chain setups, e.g. with BTC support).
# Example value for docker-compose internal network:
# WHALE_API_URL=http://whale-provider:8001
WHALE_API_URL=
WHALE_API_KEY=
WHALE_MIN_USD=100000
WHALE_POLL_INTERVAL_SECONDS=60

# Whale provider: Bitcoin settings (used by app.provider.whale_provider).
BTC_API_BASE_URL=https://blockstream.info/api
BTC_API_TIMEOUT_SECONDS=10
BTC_MAX_TXS_PER_ADDRESS=50

# Web/API settings
PROJECT_NAME=ARKANA PULSE
API_V1_STR=/api/v1
WEBAPP_URL=http://localhost:8000

# CORS: JSON list of allowed origins, e.g. ["https://your-domain.com"]
BACKEND_CORS_ORIGINS=["*"]

# Simple API key for external clients (leave empty to disable auth)
API_KEY_HEADER_NAME=X-API-Key
API_KEY=

# Rate limiting (per IP)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO

