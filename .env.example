BOT_TOKEN=your-telegram-bot-token-here
ADMIN_ID=123456789

# Optional Binance API keys (can be left empty for public data)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Redis connection string
REDIS_URL=redis://redis:6379/0

# Web/API settings
PROJECT_NAME=ARKANA PULSE
API_V1_STR=/api/v1
WEBAPP_URL=http://localhost:8000

# CORS: JSON list of allowed origins, e.g. ["https://your-domain.com"]
BACKEND_CORS_ORIGINS=["*"]

# Simple API key for external clients (leave empty to disable auth)
API_KEY_HEADER_NAME=X-API-Key
API_KEY=

# Rate limiting (per IP)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO

